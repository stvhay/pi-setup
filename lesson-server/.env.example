# Copy to .env and choose a real password before running docker compose.
POSTGRES_DB=lessons
POSTGRES_USER=lessons
POSTGRES_PASSWORD=change-me-long-random-password

# Existing reverse-proxy network that can reach lesson-api:8080.
CADDY_NETWORK=caddy

# Keep disabled unless you want /test/lesson, /test/lessons, and /test/logs.
LESSON_ENABLE_TEST_API=0
