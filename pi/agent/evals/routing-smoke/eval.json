{
  "schemaVersion": 1,
  "id": "routing-smoke",
  "summary": "Smoke-test deterministic agnt route recommendations.",
  "kind": "route",
  "cases": [
    {
      "name": "review-fast-cheap-default",
      "args": ["--task", "review", "--risk", "medium", "--budget", "cheap", "--local-ok", "--monthly-paid-spend", "0"],
      "assert": {"exitCode": 0, "routeStatus": "selected", "selected": "openrouter-localish/google/gemma-4-31b-it", "fanoutRecommended": true}
    },
    {
      "name": "orchestration-high-quality",
      "args": ["--task", "orchestration", "--risk", "high", "--budget", "quality"],
      "assert": {"exitCode": 0, "routeStatus": "selected", "selected": "openai-codex/gpt-5.6-sol", "thinkingLevel": "high"}
    },
    {
      "name": "research-long-context",
      "args": ["--task", "research", "--context-tokens", "200000"],
      "assert": {"exitCode": 0, "routeStatus": "selected", "selected": "olla-cloud/gemini-flash"}
    },
    {
      "name": "review-impossible-video-context",
      "args": ["--task", "review", "--context-tokens", "999999999", "--modality", "video"],
      "assert": {"exitCode": 1, "routeStatus": "no_candidate", "selected": false}
    }
  ]
}
