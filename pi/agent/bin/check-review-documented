#!/usr/bin/env bash
# check-review-documented — Validate that a GitHub issue has design/review/plan/verification discussion.
#
# Usage: check-review-documented --issue <N> [--repo owner/name]
#
# Exit codes:
#   0 — artifact comments found, or issue/gh unavailable and check is skipped
#   1 — issue exists but no artifact comments were found
#   2 — usage error

set -euo pipefail

ISSUE=""
REPO=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --issue) ISSUE="${2:-}"; shift 2 ;;
    --repo) REPO="${2:-}"; shift 2 ;;
    -h|--help)
      sed -n '1,12p' "$0"
      exit 0
      ;;
    *) echo "Unknown arg: $1" >&2; exit 2 ;;
  esac
done

[[ -n "$ISSUE" ]] || exit 0
command -v gh >/dev/null 2>&1 || exit 0

args=(issue view "$ISSUE" --json comments --jq '.comments[].body')
if [[ -n "$REPO" ]]; then
  args=(-R "$REPO" "${args[@]}")
fi

COMMENTS=$(gh "${args[@]}" 2>/dev/null || true)

if [[ -z "$COMMENTS" ]] || ! grep -qiE 'review|design|plan|verification|test plan|readiness' <<<"$COMMENTS"; then
  echo "Review documentation gaps:"
  if [[ -n "$REPO" ]]; then
    echo "  - GitHub: $REPO issue #$ISSUE has no review/design/plan/verification comments."
    echo "  - Post artifacts via: gh issue comment -R $REPO $ISSUE --body '## Verification ...'"
  else
    echo "  - GitHub: issue #$ISSUE has no review/design/plan/verification comments."
    echo "  - Post artifacts via: gh issue comment $ISSUE --body '## Verification ...'"
  fi
  exit 1
fi

exit 0
