#!/usr/bin/env python3
"""Generic URL fetch/content extraction helper for Pi skills."""
import argparse
import html
import re
import sys
import urllib.request

parser = argparse.ArgumentParser(description="Fetch a URL and print readable text-ish content.")
parser.add_argument("url", help="URL to fetch")
parser.add_argument("--max-chars", type=int, default=12000, help="max output chars after metadata (default: 12000)")
parser.add_argument("--raw", action="store_true", help="print raw response body")
args = parser.parse_args()

try:
    req = urllib.request.Request(
        args.url,
        headers={
            "User-Agent": "Mozilla/5.0 pi-web-fetch/1.0",
            "Accept": "text/html,application/xhtml+xml,text/plain,application/json,*/*;q=0.8",
        },
    )
    with urllib.request.urlopen(req, timeout=30) as res:
        status = res.status
        final_url = res.geturl()
        content_type = res.headers.get("content-type", "")
        body = res.read()
except Exception as e:
    print(f"web-fetch error: {e}", file=sys.stderr)
    sys.exit(1)

text = body.decode("utf-8", errors="replace")
print(f"URL: {args.url}")
print(f"Final-URL: {final_url}")
print(f"Status: {status}")
print(f"Content-Type: {content_type}\n")

if args.raw or "text/html" not in content_type.lower():
    print(text[: args.max_chars])
    sys.exit(0)

# Lightweight, dependency-free HTML to readable text. This is intentionally
# simple; use browser tools/readability when exact extraction matters.
text = re.sub(r"(?is)<(script|style|noscript|svg|nav|footer|header|aside)[^>]*>.*?</\1>", " ", text)
text = re.sub(r"(?is)<br\s*/?>", "\n", text)
text = re.sub(r"(?is)</(p|div|section|article|main|li|h[1-6]|tr)>", "\n", text)
text = re.sub(r"(?is)<[^>]+>", " ", text)
text = html.unescape(text)
text = re.sub(r"[ \t\r\f\v]+", " ", text)
text = re.sub(r"\n\s+", "\n", text)
text = re.sub(r"\n{3,}", "\n\n", text).strip()
print(text[: args.max_chars])
